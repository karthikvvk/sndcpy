<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_vertical"
    android:background="#FAFAFA">

    <!-- App title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="sndcpy"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Phone audio \u2192 PC over WiFi"
        android:textSize="14sp"
        android:textColor="#757575"
        android:gravity="center"
        android:layout_marginBottom="40dp" />

    <!-- Server IP -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_server_ip"
        android:textSize="12sp"
        android:textColor="#1565C0"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/editServerIp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_server_ip"
        android:inputType="textUri"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="20dp"
        android:imeOptions="actionNext"
        android:singleLine="true" />

    <!-- Port -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_server_port"
        android:textSize="12sp"
        android:textColor="#1565C0"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/editServerPort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_server_port"
        android:inputType="number"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="32dp"
        android:imeOptions="actionDone"
        android:singleLine="true" />

    <!-- Start button -->
    <Button
        android:id="@+id/btnStartStop"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_start_streaming"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1565C0"
        android:layout_marginBottom="24dp" />

    <!-- Status text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/status_idle"
        android:textSize="14sp"
        android:textColor="#757575"
        android:gravity="center"
        android:layout_marginTop="8dp" />

</LinearLayout>
